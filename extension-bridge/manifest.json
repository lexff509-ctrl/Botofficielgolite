{
  "manifest_version": 3,
  "name": "BotOfficiel Bridge",
  "version": "1.2.0",
  "description": "Connexion automatisée PocketOption — Stable MV3",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.pocketoption.com/*",
    "*://*.po.market/*",
    "https://botofficielgolite.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.pocketoption.com/*", "*://*.po.market/*"],
      "js": ["content-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.pocketoption.com/*", "*://*.po.market/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
